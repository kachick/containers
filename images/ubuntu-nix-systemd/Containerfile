FROM public.ecr.aws/docker/library/buildpack-deps:24.04-scm@sha256:d7a4da4017ffb4e89c6cc9acda1fcd489954f2093a5ec4b7dc6e7f5e20a5cef7


LABEL org.opencontainers.image.source=https://github.com/kachick/containers
LABEL org.opencontainers.image.description="Nix package manager on Ubuntu - systemd"
LABEL org.opencontainers.image.licenses=MIT

# Available versions in apt: https://packages.ubuntu.com/noble/curl
# --no-install-recommends omits ca-certificates
RUN apt-get update \
 && apt-get install --no-install-recommends -y systemd \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

ENV PATH="${PATH}:/nix/var/nix/profiles/default/bin"

# AFAIK, we can not use original installer for this purpose because it does not have options similar to `--no-start-daemon`
# Instead, https://github.com/NixOS/nix-installer is now an official and modernized beta installer.
#
# * accept-flake-config: Potentially insecure setting, but reasonable for this container image
RUN curl --proto '=https' --tlsv1.2 -sSf -L https://artifacts.nixos.org/nix-installer | sh -s -- install linux \
  --extra-conf "sandbox = false" \
  --extra-conf "trusted-users = root user" \
  --extra-conf "extra-trusted-substituters = https://nix-community.cachix.org https://cache.garnix.io https://cache.numtide.com https://selfup.cachix.org https://kachick-dotfiles.cachix.org" \
  --extra-conf "extra-trusted-public-keys = nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Fs= cache.garnix.io:CTFPyKSLcx5RMJKfLo5EEPUObbA78b0YQ2DTCJXqr9g= niks3.numtide.com-1:DTx8wZduET09hRmMtKdQDxNNthLQETkc/yaX7M4qK0g= selfup.cachix.org-1:eY2eEd955BmRI7SultbRIV81vApqpJixunkV3XlXuT8= kachick-dotfiles.cachix.org-1:XhiP3JOkqNFGludaN+/send30shcrn1UMDeRL9XttkI=" \
  --extra-conf "accept-flake-config = true" \
  --no-start-daemon \
  --no-confirm

# TODO: Consider to extract from this repository
ARG username="user"
RUN useradd --no-log-init --create-home $username

CMD [ "/bin/systemd", "--system" ]
